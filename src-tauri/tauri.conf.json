{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ghost Vessel",
  "version": "0.1.0",
  "identifier": "space.ghostvessel.app",
  "build": {
    "frontendDist": "../player",
    "devUrl": "http://127.0.0.1:8777/player/index.html",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ghost Vessel — 여름",
        "url": "http://127.0.0.1:8777/player/index.html",
        "width": 980,
        "height": 720,
        "minWidth": 640,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
