{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ghost Vessel",
  "version": "0.1.0",
  "identifier": "space.ghostvessel.app",
  "build": {
    "frontendDist": "../player",
    "devUrl": "http://127.0.0.1:8777/player/index.html",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "video",
        "title": "Ghost Vessel — 여름",
        "url": "http://127.0.0.1:8777/player/index.html?pane=video",
        "width": 360,
        "height": 640,
        "minWidth": 220,
        "minHeight": 340,
        "x": 60,
        "y": 60,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      },
      {
        "label": "chat",
        "title": "Ghost Vessel — Chat",
        "url": "http://127.0.0.1:8777/player/index.html?pane=chat",
        "width": 400,
        "height": 560,
        "minWidth": 300,
        "minHeight": 320,
        "x": 440,
        "y": 60,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
