{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ghost Vessel",
  "version": "0.1.0",
  "identifier": "space.ghostvessel.app",
  "build": {
    "frontendDist": "../player",
    "devUrl": "http://127.0.0.1:8777/player/index.html",
    "beforeDevCommand": "start cmd /c launch.bat",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "video",
        "title": "Ghost Vessel — 여름",
        "url": "index.html?pane=video",
        "width": 360,
        "height": 640,
        "minWidth": 220,
        "minHeight": 340,
        "x": 60,
        "y": 60,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      },
      {
        "label": "chat",
        "title": "Ghost Vessel — Chat",
        "url": "index.html?pane=chat",
        "width": 400,
        "height": 560,
        "minWidth": 300,
        "minHeight": 320,
        "x": 440,
        "y": 60,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8898 http://127.0.0.1:8899 http://127.0.0.1:8900 http://127.0.0.1:8777 ws://127.0.0.1:18790 https://namanavi.com https://ghostvessel.space; media-src 'self' blob: http://127.0.0.1:8899 http://127.0.0.1:8900; img-src 'self' data: blob: http://127.0.0.1:8900; font-src 'self' data: http://127.0.0.1:8900 https://fonts.gstatic.com; frame-src 'none'; object-src 'none'",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
