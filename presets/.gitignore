# Private presets are not published to the open-source engine repo.
# The engine ships with _template/ only; personal avatars (mina-default) and any
# paid packs stay local / sold separately.
mina-default/
*/avatar/segments/
*/avatar/source.*
*.woff2
*.woff
*.ttf
*.otf

# …except the free starter avatar, which ships WITH the engine so that cloning the
# repo gives you something that actually runs. Built with free local tools; it is the
# one bundle we intentionally publish.
!gv-starter/
!gv-starter/avatar/
!gv-starter/avatar/segments/
!gv-starter/avatar/segments/*.mp4
!gv-starter/avatar/source.png
# keep the template + docs tracked (active.txt is install-local → not tracked;
# the loader defaults to _template when it's absent)
!_template/
!README.md
!.gitignore
